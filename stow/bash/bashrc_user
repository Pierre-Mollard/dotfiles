#!/usr/bin/bash

# If not running interactively, don't do anything (leave this at the top of this file)
[[ $- != *i* ]] && return

# Load git keys (private key must be name github)
# Dont restart agent if already running
if [ -z "$SSH_AUTH_SOCK" ]; then
  eval "$(ssh-agent -s)" >/dev/null 2>&1
fi

# Add default SSH key (adjust path if needed)
ssh-add ~/.ssh/github >/dev/null 2>&1

export PATH="/opt/nvim/bin:$PATH"

alias gg="~/projects/dotfiles/scripts/tmux_basic_session.sh"

PS1='\[\033[01;33m\]\u\[\033[00m\]@\[\033[01;35m\]\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '

export OLLAMA_CONTEXT_LENGTH=64000

eval "$(starship init bash)"

# Modern CLI replacements with automatic fallbacks
unalias ls grep cat cp 2>/dev/null

ls() {
  if command -v lsd >/dev/null 2>&1; then
    command lsd --color=auto "$@"
  else
    command ls --color=auto "$@"
  fi
}

cat() {
  if command -v bat >/dev/null 2>&1; then
    command bat --color=always --paging=never "$@"
  else
    command cat "$@"
  fi
}

cp() {
  if command -v xcp >/dev/null 2>&1; then
    command xcp "$@"
  else
    command cp "$@"
  fi
}

grep() {
  if command -v rg >/dev/null 2>&1; then
    command rg --color=auto "$@"
  else
    command grep --color=auto "$@"
  fi
}
